# OpenShell sandbox policy generated by Trustabl from a read-only scan.
# Self-contained: suitable for sandbox creation and `openshell policy set`.
# Lifecycle: filesystem_policy and process are LOCKED at sandbox creation;
# only network_policies hot-reload. Values marked 'trustabl:' need human
# attention before use.
version: 1
filesystem_policy:
  include_workdir: true
  read_only: [/usr, /lib, /proc, /dev/urandom, /app, /etc, /var/log]
  read_write: [/dev/null, /sandbox, /tmp, /workspace/archive/report.txt, /workspace/out/report.txt]
landlock:
  compatibility: best_effort # alternative: hard_requirement fails closed when the kernel lacks Landlock
# run_as_user/group must be 'sandbox' (OpenShell-enforced).
# BYOC note: `sandbox create --from <image>` clears these because a custom
# image may lack a 'sandbox' user.
process:
  run_as_user: sandbox
  run_as_group: sandbox
network_policies:
  fetch_status:
    name: fetch-status
    endpoints:
      - host: status.example.com
        port: 443
        protocol: rest
        enforcement: enforce
        access: read-only # trustabl: suggested — confirm — method usage is not provable from code
    binaries:
      - path: /usr/bin/python3 # trustabl: review — confirm the interpreter path inside the sandbox
